
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA GLOBALES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica si el usuario es administrador consultando la colección protegida
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true;
    }

    // Validadores de tipos de datos para prevenir inyecciones
    function isValidString(val) { return val is string && val.size() > 0; }
    function isValidBool(val) { return val is bool; }

    // --- REGLAS DE COLECCIONES ---

    match /siteConfigurations/{siteConfigurationId} {
      // Configuración pública para lectura, pero solo admin puede tocar
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      // Nadie puede crear administradores desde la app (solo consola de Firebase)
      // Un usuario solo puede leer su propio perfil de admin
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    match /tourVisits/{visitId} {
      // Registro de visitas (Telemetría interna)
      allow create: if request.resource.data.keys().hasAll(['tourId', 'timestamp', 'userAgent'])
                    && request.resource.data.tourId is string
                    && request.resource.data.timestamp is number;
      
      // Permitimos actualizar duración y conversiones. 
      // Validamos que no se alteren los datos base de la visita.
      allow update: if request.resource.data.tourId == resource.data.tourId
                    && request.resource.data.timestamp == resource.data.timestamp
                    && (request.resource.data.duration is number || !request.resource.data.keys().contains('duration'))
                    && (request.resource.data.contacted is bool || !request.resource.data.keys().contains('contacted'))
                    && (request.resource.data.contactMethods is list || !request.resource.data.keys().contains('contactMethods'));

      // Solo el administrador autorizado puede consultar o borrar las estadísticas
      allow get, list, delete: if isAdmin();
    }

    match /tours/{tourId} {
      // El público solo ve propiedades publicadas. Admin ve todo.
      allow get, list: if resource.data.published == true || isAdmin();
      
      // Solo admin puede crear/editar propiedades
      allow create, update: if isAdmin() && 
        isValidString(request.resource.data.name) && 
        isValidString(request.resource.data.slug);
      allow delete: if isAdmin();

      match /scenes/{sceneId} {
        // Hereda la visibilidad de la propiedad padre
        allow get, list: if get(/databases/$(database)/documents/tours/$(tourId)).data.published == true || isAdmin();
        allow create, update, delete: if isAdmin();

        match /hotspots/{hotspotId} {
          allow get, list: if get(/databases/$(database)/documents/tours/$(tourId)).data.published == true || isAdmin();
          allow create, update, delete: if isAdmin();
        }
      }
    }
  }
}
